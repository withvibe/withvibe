# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `docker compose` reads it automatically.
# ---------------------------------------------------------------------------

# ----- Postgres ------------------------------------------------------------
# Used by the postgres service AND by the api's DATABASE_URL below.
# POSTGRES_PASSWORD is REQUIRED — `docker compose up` fails fast if it's
# unset, and a placeholder is rejected. Generate: `openssl rand -hex 24`.
POSTGRES_USER=withvibe
POSTGRES_PASSWORD=CHANGEME-generate-with-openssl-rand-hex-24
POSTGRES_DB=withvibe

# ----- API -----------------------------------------------------------------
# Signs every session + bridge/MCP/WS token. REQUIRED. The api refuses to
# boot in production on an empty/short/placeholder value. A guessable secret
# lets anyone forge admin sessions. Generate: `openssl rand -hex 32`.
INTERNAL_JWT_SECRET=CHANGEME-generate-with-openssl-rand-hex-32

# Anthropic key — required for Claude agent runs.
ANTHROPIC_API_KEY=

# Optional: Google OAuth login. Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: GitHub PAT for default repo cloning. Per-workspace tokens override.
GITHUB_TOKEN=

# Public-facing URLs — set to whatever the browser uses to reach the stack.
# For a single dev box reachable at localhost, the defaults below are fine.
# For a remote VM, set both to the VM's hostname (e.g. http://10.0.0.5:3000).
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Hostname that env-services (the user's compose stacks) advertise. The
# template materializer substitutes this into ${PUBLIC_HOST}. Use the host
# the browser will actually reach (e.g. the VM's hostname/IP).
PUBLIC_HOST=localhost

# Where the API stores per-env clones on the host. Bind-mounted into the
# api container at the SAME path so DooD-spawned compose stacks can resolve
# the path against the host filesystem. Default: ~/.withvibe/repos.
REPO_BASE_DIR=${HOME}/.withvibe/repos

# Wildcard base domain for subdomain-routed env services. Point this at a
# domain whose *.<domain> resolves to THIS host. Leave unset for local /
# single-host installs — it then defaults to "localhost" (NOT a vendor
# domain). The CLI sets this automatically when you configure Traefik.
# WITHVIBE_ROUTING_BASE_DOMAIN=envs.example.com

# Optional: log verbosity.
LOG_LEVEL=info
DEMO_TEMPLATE_REPOS=https://github.com/withvibe/vibe-aquarium.git