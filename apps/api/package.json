    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^11.3.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
