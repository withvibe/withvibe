    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@prisma/client": "^7.7.0",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "@withvibe/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "md-to-pdf": "^5.2.5",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.1.0",
    "node-pty": "^1.1.0",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "playwright-core": "^1.59.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
