{
  "name": "@withvibe/api",
  "version": "0.2.5",
  "private": true,
  "license": "Elastic-2.0",
  "scripts": {
    "dev": "rm -f tsconfig.build.tsbuildinfo && rm -rf dist && nest start --watch",
    "start": "nest start",
    "start:dev": "rm -f tsconfig.build.tsbuildinfo && rm -rf dist && nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "rm -f tsconfig.build.tsbuildinfo && nest build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "bench:chat": "ts-node -r tsconfig-paths/register src/chat/bench/run-bench.ts",
    "check:compose-security": "ts-node -r tsconfig-paths/register src/docker/compose-security.check.ts",
    "check:compose-rewriter": "ts-node -r tsconfig-paths/register src/templates/compose-rewriter.check.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
