API_PORT=4000
# Local dev only. Use a strong password and never reuse this in any shared
# or deployed environment.
DATABASE_URL=postgresql://postgres:CHANGEME-local-dev-only@localhost:5432/withvibe

# Signs both the user session JWT (issued at login, stored in the
# `withvibe_session` HTTP-only cookie) and the legacy web→api bridge JWT.
# Must match across all server processes. Rotate carefully — every existing
# session is invalidated when this changes.
#
# REQUIRED. The api refuses to boot when NODE_ENV=production if this is
# empty, under 32 chars, or a placeholder like the one below (see
# common/startup-secrets.ts). Generate a real one: `openssl rand -hex 32`.
INTERNAL_JWT_SECRET=CHANGEME-local-dev-only-generate-with-openssl-rand-hex-32

# Absolute path where cloned repos for environments are stored.
REPO_BASE_DIR=/absolute/path/to/shared-ai-repos

# Public URL of this API (used to build the Google OAuth callback URL).
API_PUBLIC_URL=http://localhost:4000

# Public URL of the web app (where Google OAuth redirects after login).
WEB_PUBLIC_URL=http://localhost:3000

# Anthropic API key — used as the workspace-level fallback when a workspace
# doesn't have its own key configured.
ANTHROPIC_API_KEY=

# Google OAuth credentials (optional; leave empty to disable Google login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cookie security — set COOKIE_SECURE=true behind HTTPS in production.
# COOKIE_SECURE auto-enables when NODE_ENV=production. Override either way.
# COOKIE_DOMAIN is only needed when API + Web are on different subdomains.
# COOKIE_SECURE=
# COOKIE_DOMAIN=

# Comma-separated list of public GitHub repo URLs auto-added to every new
# workspace as demo templates. Leave empty to disable. Public repos only —
# no GitHub token required.
# DEMO_TEMPLATE_REPOS=https://github.com/owner/demo-next,https://github.com/owner/demo-py

# Wildcard base domain for subdomain-routed env services. Point this at a
# domain whose *.<domain> resolves to THIS host. Unset ⇒ defaults to
# "localhost" (NOT a vendor domain) for local / from-source installs.
# WITHVIBE_ROUTING_BASE_DOMAIN=envs.example.com
