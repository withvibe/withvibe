# code-server (browser-served VS Code) for the per-env "Open in VS Code (Browser)"
# action. CodeServerService spawns one container per env, mounts the env dir
# at /home/coder/workspace, and opens the multi-root .code-workspace
# generated by CodeWorkspaceService.
#
# Built automatically by CodeServerService when the `withvibe-code-server`
# image is missing. Manual:
#   docker build -t withvibe-code-server apps/api/code-server-image
# Override with CODE_SERVER_IMAGE if you want to pin a registry-hosted tag.

FROM codercom/code-server:latest

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      curl \
      ca-certificates \
      jq \
      ripgrep \
      tini \
    && rm -rf /var/lib/apt/lists/*

# Install Node so the Claude Code CLI (which the extension shells out to) can
# run inside the container. The extension auto-discovers `claude` on PATH and
# picks up ANTHROPIC_API_KEY from the env (CodeServerService injects it from
# the workspace's stored key).
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code || true

USER coder

# Pre-install the Claude Code VS Code extension. code-server's default
# extension gallery is Open VSX, which may not have `anthropic.claude-code`,
# so we try Open VSX first and fall back to fetching the .vsix directly from
# the Microsoft marketplace by name (no version pinning — uses "latest").
# The whole step is `|| true` so an offline build still produces a working
# image; the user can install manually from the recommendations prompt
# generated by CodeWorkspaceService.
RUN set -eux; \
    if code-server --install-extension anthropic.claude-code; then \
        echo "Installed anthropic.claude-code from Open VSX"; \
    else \
        echo "Open VSX install failed — falling back to MS marketplace .vsix"; \
        curl -fsSL -o /tmp/claude-code.vsix \
            "https://marketplace.visualstudio.com/_apis/public/gallery/publishers/anthropic/vsextensions/claude-code/latest/vspackage" \
            && code-server --install-extension /tmp/claude-code.vsix \
            && rm /tmp/claude-code.vsix; \
    fi || true
